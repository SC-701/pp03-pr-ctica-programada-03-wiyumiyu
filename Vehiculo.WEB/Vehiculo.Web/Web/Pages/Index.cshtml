@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<div class="hero">
    <div class="hero-content text-center">
        <h1 class="display-2 fw-bold">🚗 Bienvenido</h1>
        <p class="lead mt-3">
            Sistema inteligente de gestión de vehículos
        </p>

        <a asp-page="/Vehiculos/Index" class="btn btn-light btn-lg mt-4 shadow">
            Ver Vehículos
        </a>
    </div>
</div>

<div class="container mt-5 text-center fade-in">
    <h2 class="fw-bold mb-4">Control total de tu flota</h2>

    <div class="row">
        <div class="col-md-4 mb-4">
            <h3>🚘</h3>
            <p class="text-muted">Visualiza todos los vehículos en un solo lugar.</p>
        </div>

        <div class="col-md-4 mb-4">
            <h3>⚡</h3>
            <p class="text-muted">Accede rápido a la información que necesitas.</p>
        </div>

        <div class="col-md-4 mb-4">
            <h3>🔒</h3>
            <p class="text-muted">Sistema seguro y escalable.</p>
        </div>
    </div>
</div>